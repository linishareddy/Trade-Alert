# ── App ───────────────────────────────────────────────
ENVIRONMENT=development
API_V1_STR=/api/v1

# ── Discord Self-Bot ───────────────────────────────────
DISCORD_USER_TOKEN=your_user_token_here
DISCORD_TARGET_CHANNEL_IDS=123456789,987654321

# ── Database ───────────────────────────────────────────
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradealert

# ── Broker selection ───────────────────────────────────
# Change this ONE line to swap brokers: "alpaca" | "webull"
BROKER=alpaca

# ── Trade rules (apply to all brokers) ────────────────
EXECUTION_ENABLED=false       # set true when ready to paper trade
TAKE_PROFIT_PCT=0.15          # 15%
STOP_LOSS_PCT=0.10            # 10%
DEFAULT_QTY=1
MARKET_HOURS_ONLY=true
MARKET_TIMEZONE=America/New_York
MARKET_OPEN=09:30
MARKET_CLOSE=16:00

# ── Alpaca Paper Trading ───────────────────────────────
# Sign up free at alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_PAPER=true             # false = real money

# ── Market Data ────────────────────────────────────────
# Options: "yfinance" | "alpaca"
MARKET_DATA_PROVIDER=yfinance

# ── AI Parsing (Groq) ──────────────────────────────────
GROQ_API_KEY=your_groq_key
AI_PARSING_ENABLED=true

# ── Webull (used when BROKER=webull) ──────────────────
WEBULL_APP_KEY=
WEBULL_APP_SECRET=
WEBULL_ACCOUNT_ID=
WEBULL_ENDPOINT=us-openapi-alb.uat.webullbroker.com
