# ── App ──────────────────────────────────────────
ENVIRONMENT=development
API_V1_STR=/api/v1

# ── Discord Self-Bot ──────────────────────────────
# Get token: Chrome → DevTools → Network → any api.discord.gg request → authorization header
DISCORD_USER_TOKEN=your_user_token_here
# Comma-separated list of channel IDs to listen to
DISCORD_TARGET_CHANNEL_IDS=123456789

# ── Database ─────────────────────────────────────
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradealert

# ── Queue / Cache (uncomment when ready) ─────────
# REDIS_URL=redis://localhost:6379/0
GROQ_API_KEY=
